# API Keys
OPENAI_API_KEY=sk-...
ANTHROPIC_API_KEY=sk-ant-...

# Entrez (PubMed API)
ENTREZ_EMAIL=your@email.com

# MCP Server (medwriter-server, uruchamiany niezależnie)
MCP_SERVER_URL=http://<medwriter-server-ip>:8001/mcp

# Database
POSTGRES_PASSWORD=change-me-to-something-secure
DATABASE_URL=postgresql+asyncpg://medwriter:change-me-to-something-secure@localhost:5432/medwriter_db

# Redis
REDIS_URL=redis://localhost:6379/0

# Worker
WORKER_ID=worker-1

# Logging
LOG_LEVEL=INFO
LOG_FILE=logs/medwriter.log
