{
  "agent": {
    "llm_provider": "openai",
    "model_name": "gpt-4.1-mini",
    "temperature": 0.7,
    "max_tokens": 4096,
    "max_steps": 15
  },
  "pdf": {
    "chunker": {
      "type": "sentence",
      "params": {
        "chunk_size": 1000,
        "chunk_overlap": 200
      }
    },
    "top_k": 5
  },
  "context": {
    "max_messages": 20,
    "title_generator": {
      "model_name": "gpt-4o-mini",
      "temperature": 0.7,
      "max_tokens": 50
    },
    "article_summarizer": {
      "enabled": false,
      "model_name": "gpt-4o-mini",
      "temperature": 0.3,
      "max_tokens": 200,
      "word_count_threshold": 500
    }
  }
}
